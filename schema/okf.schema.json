{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OKF Frontmatter v1.0",
  "type": "object",
  "required": [
    "okf_version", "doc_id", "title", "type", "role", "project",
    "version", "status", "owner", "created", "updated",
    "audience", "summary", "changelog"
  ],
  "properties": {
    "okf_version": { "const": "1.0" },
    "doc_id": { "type": "string", "pattern": "^[A-Z]+-[A-Z]+-[A-Z0-9]+-\\d{3}$" },
    "title": { "type": "string", "maxLength": 120 },
    "type": {
      "enum": [
        "Plan", "Status", "Risk", "Milestone", "URD", "SRS",
        "UserStory", "UseCase", "BusinessRule", "Architecture",
        "IntegrationMap", "KT", "TechDesign", "ADR", "Convention",
        "TestScenario", "UAT", "Other"
      ]
    },
    "role": { "enum": ["PM", "BA", "SA", "DEV", "QA", "Shared"] },
    "project": { "type": "string" },
    "domain": { "type": "string" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "status": { "enum": ["draft", "in_review", "approved", "deprecated", "archived"] },
    "language": { "enum": ["vi", "en"], "default": "vi" },
    "owner": { "type": "string" },
    "contributors": { "type": "array", "items": { "type": "string" } },
    "created": { "type": "string", "format": "date" },
    "updated": { "type": "string", "format": "date" },
    "review_by": { "type": "string", "format": "date" },
    "audience": {
      "type": "array",
      "items": { "enum": ["human", "machine"] },
      "minItems": 1
    },
    "summary": { "type": "string" },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "source": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["system", "ref"],
        "properties": {
          "system": { "enum": ["jira", "drive", "kb", "confluence", "manual"] },
          "ref": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "related": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z]+-[A-Z]+-[A-Z0-9]+-\\d{3}$" }
    },
    "access": { "enum": ["public", "internal", "restricted"], "default": "internal" },
    "template_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "changelog": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["version", "date", "author", "change"],
        "properties": {
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "date": { "type": "string", "format": "date" },
          "author": { "type": "string" },
          "change": { "type": "string" }
        }
      }
    }
  }
}
